@baseURL = http://localhost:3000
@token = 

### 1 - Cadastrar usuário admin
POST {{baseURL}}/users
Content-Type: application/json

{
  "name": "Admin Sistema",
  "email": "admin@email.com",
  "password": "123456",
  "phone": "51999999999",
  "role": "admin"
}

###

### 2 - Cadastrar usuário adopter
POST {{baseURL}}/users
Content-Type: application/json

{
  "name": "Maria Silva",
  "email": "maria@email.com",
  "password": "123456",
  "phone": "51988888888",
  "role": "adopter"
}

###

### 3 - Login admin
POST {{baseURL}}/login
Content-Type: application/json

{
  "email": "admin@email.com",
  "password": "123456"
}

###

### 4 - Login adopter
POST {{baseURL}}/login
Content-Type: application/json

{
